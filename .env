


# ML Backend API
ML_BACKEND_URL=https://rppooo-dog-backend.hf.space
ML_API_KEY=your_api_key_here
PREDICT_ENDPOINT=/predict
MODEL_INFO_ENDPOINT=/model-info

# Database
DATABASE_URL=sqlite+aiosqlite:///./monitoring.db

# Alert Settings
ALERT_EMAIL=your@email.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/...

# Monitoring Settings
MONITORING_INTERVAL_SECONDS=60
DAILY_EVAL_HOUR=2
WEEKLY_EVAL_DAY=0

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080